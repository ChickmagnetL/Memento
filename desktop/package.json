{
  "name": "memento-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "node --test"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "deno": "2.9.2",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "dev.leo.memento",
    "productName": "Memento",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "build/icon.png",
      "window-options.js",
      "preload.js",
      "login-manager.js",
      "login-shell.html",
      "video-player.js",
      "cookie-refresh.js"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend"
      },
      {
        "from": "resources/frontend",
        "to": "frontend"
      },
      {
        "from": "resources/douyin-fetcher",
        "to": "douyin-fetcher"
      },
      {
        "from": "resources/bin",
        "to": "bin"
      },
      {
        "from": "resources/services",
        "to": "services"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "Memento-macOS.${ext}",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Memento-Windows.${ext}",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "uninstallDisplayName": "${productName}"
    }
  }
}
